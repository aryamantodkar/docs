  "keyFeatures": [
    "Multi-provider AI monitoring (ChatGPT, Claude, Perplexity, Gemini, Google AI Overview)",
    "Automated browser sessions with Playwright for authentic prompt responses",
    "Scheduled prompt execution with BullMQ and Redis queues",
    "Sentiment and visibility analysis with OpenAI",
    "Team workspaces with role-based access control",
    "Real-time metrics dashboard with historical tracking",
    "Source citation extraction and analysis",
    "Cron-based scheduling with customizable frequency"
